# === OpenAI (DALL-E 3 for thumbnails) ===
OPENAI_API_KEY=sk-...

# === fal.ai Configuration (legacy — replaced by DALL-E 3) ===
FAL_KEY=fal-...
DEFAULT_IMAGE_MODEL=fal-ai/fast-sdxl
DEFAULT_VIDEO_MODEL=fal-ai/wan-2.1/image-to-video

# === ElevenLabs Configuration ===
ELEVENLABS_API_KEY=...
VOICE_ID_ANIME=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_v3

# === YouTube Configuration ===
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_CREDENTIALS_PATH=.youtube_credentials.json

# === Background Music ===
# Option A: YouTube URL mode — no key needed, just pass --url to fetch_bgm.py
# Option B: Freesound search — free key at https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=

# === General Settings ===
MAX_PARALLEL_IMAGE_REQUESTS=5
MAX_PARALLEL_VIDEO_REQUESTS=3
OUTPUT_BASE_DIR=output

# === Video Duration (seconds) ===
# Anime Shorts: 30-60s (YouTube Shorts format, viral reach)
DURATION_ANIME_SHORT=60
# Anime Normal: 3-8 min (narrative videos, lore, stories)
DURATION_ANIME_NORMAL=300
